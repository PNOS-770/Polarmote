    {
      "id": "script-1772075599886819",
      "name": "frp服务器端配置",
      "folderId": "script-folder-1781922596120123-0",
      "commands": [
        "mkdir -p frp",
        "tar -zxvf frp_0.67.0_linux_amd64.tar.gz",
        "cat > /root/frp/frp_0.67.0_linux_amd64/frps.toml << 'EOF'\r\nbindPort = 7000\r\nauth.token = \"mc_pokemon\"\r\nlog.level = \"info\"\r\nlog.file = \"/root/frp/frp_0.67.0_linux_amd64/frps.log\"\r\nEOF",
        "cat > /etc/systemd/system/frps.service << 'EOF'\r\n[Unit]\r\nDescription = frp server\r\nAfter = network.target syslog.target\r\nWants = network.target\r\n[Service]\r\nType = simple\r\nExecStart = /root/frp/frp_0.67.0_linux_amd64/frps -c /root/frp/frp_0.67.0_linux_amd64/frps.toml\r\nRestart = always\r\nRestartSec = 5\r\n[Install]\r\nWantedBy = multi-user.target\r\nEOF",
        "sudo systemctl daemon-reload",
        "sudo systemctl stop frps",
        "sudo systemctl start frps",
        "sudo systemctl enable frps"
      ],
      "createdAt": "2026-02-26T11:13:19.886819",
      "updatedAt": "2026-06-20T10:30:09.807695",
      "lastRunConfig": {
        "hostIds": [],
