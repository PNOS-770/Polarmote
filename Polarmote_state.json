    {
      "id": "script-publish-release",
      "name": "Publish Release",
      "commands": [
        "cd \\srcqaq\\Asmote",
        "flutter build apk --release --no-tree-shake-icons",
        "Copy-Item build/app/outputs/flutter-apk/app-release.apk Asmote-android.apk",
        "flutter build windows --release",
        "Compress-Archive -Path build/windows/x64/runner/Release/* -DestinationPath Asmote-windows.zip",
        "$_v = if ((Get-Content pubspec.yaml -Raw) -match 'version:\\s*([\\d\\.\\+]+)') { $Matches[1] }; gh release create \"v$_v\" Asmote-android.apk, Asmote-windows.zip --generate-notes",
        "Remove-Item Asmote-android.apk, Asmote-windows.zip -Force"
      ],
      "createdAt": "2026-06-08T23:00:00.000",
      "updatedAt": "2026-06-17T12:06:46.928058",
      "precheckCommands": [
        "if (-not (Get-Command gh -ErrorAction SilentlyContinue)) { throw 'gh CLI not found. Install: winget install GitHub.cli' }",
        "if (-not (gh auth status 2>&1)) { throw 'Not logged into GitHub. Run: gh auth login' }",
        "if (Test-Path 'build/windows/x64/pdfium/chromium%2F7202' -PathType Container -ErrorAction SilentlyContinue) { New-Item -ItemType Junction -Path 'build/windows/x64/pdfium/chromium/7202' -Target 'build/windows/x64/pdfium/chromium%2F7202' -Force | Out-Null }"
      ],
      "lastRunConfig": {
        "hostIds": [
          "host-1771825080027079"
        ],
